<script is:inline>
(function () {
  const STORAGE_KEY = 'edrone_first_steps_pl_v1';
  const TOTAL_STEPS = 9;
  const PHASE_STEPS = { 1: [1,2,3], 2: [4,5,6], 3: [7,8,9] };

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : { done: [], celebrated: false };
    } catch (e) {
      return { done: [], celebrated: false };
    }
  }

  function saveState(state) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
  }

  let state = loadState();

  function render() {
    const doneCount = state.done.length;
    const pct = Math.round((doneCount / TOTAL_STEPS) * 100);

    // Progress bar + count
    const fill = document.getElementById('progress-fill');
    const count = document.getElementById('progress-count');
    if (fill) fill.style.width = pct + '%';
    if (count) count.textContent = doneCount;

    // Phase dots
    for (let p = 1; p <= 3; p++) {
      const dot = document.getElementById('phase-dot-' + p);
      if (!dot) continue;
      const stepsInPhase = PHASE_STEPS[p];
      const doneInPhase = stepsInPhase.filter(n => state.done.includes(n)).length;
      dot.classList.remove('partial', 'done');
      if (doneInPhase === stepsInPhase.length) dot.classList.add('done');
      else if (doneInPhase > 0) dot.classList.add('partial');
    }

    // Step cards
    document.querySelectorAll('.step').forEach(card => {
      const num = parseInt(card.dataset.step, 10);
      const isDone = state.done.includes(num);
      card.classList.toggle('done', isDone);
      const check = card.querySelector('.step-check');
      if (check) check.setAttribute('aria-checked', isDone ? 'true' : 'false');
      const btn = card.querySelector('.action-done');
      if (btn) {
        btn.textContent = isDone ? 'Zrobione ✓' : 'Oznacz jako zrobione';
        btn.classList.toggle('checked', isDone);
      }
    });

    // Celebration
    if (doneCount === TOTAL_STEPS && !state.celebrated) {
      showCelebration();
      state.celebrated = true;
      saveState(state);
    }
  }

  function toggleStep(num) {
    const idx = state.done.indexOf(num);
    if (idx === -1) state.done.push(num);
    else state.done.splice(idx, 1);
    if (state.done.length < TOTAL_STEPS) state.celebrated = false;
    saveState(state);
    render();
    if (window.dataLayer) {
      window.dataLayer.push({ event: 'first_steps_toggle', step: num, done: idx === -1 });
    }
  }

  function openCard(num, force) {
    const card = document.getElementById('step-' + num);
    if (!card) return;
    if (force === true) card.classList.add('open');
    else if (force === false) card.classList.remove('open');
    else card.classList.toggle('open');
  }

  function showCelebration() { document.getElementById('celebration').classList.add('show'); }
  function hideCelebration() { document.getElementById('celebration').classList.remove('show'); }

  // Wire up checkboxes
  document.querySelectorAll('.step-check').forEach(el => {
    el.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleStep(parseInt(el.dataset.check, 10));
    });
    el.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        toggleStep(parseInt(el.dataset.check, 10));
      }
    });
  });

  // Wire up "Mark done" buttons
  document.querySelectorAll('.action-done').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleStep(parseInt(btn.dataset.done, 10));
    });
  });

  // Wire up header toggle
  document.querySelectorAll('.step-header').forEach(header => {
    header.addEventListener('click', (e) => {
      if (e.target.closest('.step-check')) return;
      openCard(parseInt(header.dataset.toggle, 10));
    });
  });

  // Reset
  const resetBtn = document.getElementById('reset-btn');
  if (resetBtn) {
    resetBtn.addEventListener('click', () => {
      if (state.done.length === 0) return;
      if (confirm('Zresetować postęp pierwszych kroków?')) {
        state = { done: [], celebrated: false };
        saveState(state);
        render();
      }
    });
  }

  // Celebration close
  const celebClose = document.getElementById('celebration-close');
  if (celebClose) celebClose.addEventListener('click', hideCelebration);
  document.getElementById('celebration').addEventListener('click', (e) => {
    if (e.target.id === 'celebration') hideCelebration();
  });

  // Open first undone card on load
  const firstUndone = [1,2,3,4,5,6,7,8,9].find(n => !state.done.includes(n));
  if (firstUndone) openCard(firstUndone, true);

  render();
})();
</script>

