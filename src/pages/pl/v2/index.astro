  <script is:inline>
    // ── FAQ Accordion ──
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.parentElement;
        const wasOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item.open').forEach(i => i.classList.remove('open'));
        if (!wasOpen) item.classList.add('open');
      });
    });

    // ── Scroll Fade-Up ──
    (function() {
      const fadeEls = document.querySelectorAll('.fade-up');
      if (!('IntersectionObserver' in window)) {
        fadeEls.forEach(el => el.classList.add('visible'));
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
      fadeEls.forEach(el => observer.observe(el));
      setTimeout(() => fadeEls.forEach(el => el.classList.add('visible')), 2000);
    })();

    // ── CTA Click Tracking ──
    document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', { link_url: btn.href, link_text: btn.textContent.trim(), page_location: window.location.pathname });
        }
      });
    });

    // ── UTM Params Forwarding ──
    (function() {
      const params = new URLSearchParams(window.location.search);
      const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
      const utmParams = new URLSearchParams();
      utmKeys.forEach(k => { if (params.get(k)) utmParams.set(k, params.get(k)); });
      if (!utmParams.toString()) {
        utmParams.set('utm_source', 'roi-landing');
        utmParams.set('utm_medium', 'pl-v2');
        utmParams.set('utm_campaign', 'pl-v2-2026');
      }
      document.querySelectorAll('a[href*="control.edrone.me/register"]').forEach(a => {
        const url = new URL(a.href);
        utmParams.forEach((v, k) => url.searchParams.set(k, v));
        a.href = url.toString();
      });
    })();

    // ── Revenue Calculator ──
    (function() {
      const INDUSTRY_DATA = {
        ELECTRONICS: { revPer1000: 23421.80, revUnknown1000: 17566.35, revNewsletter1000: 2342.18 },
        SPORT_EQUIPMENT: { revPer1000: 19991.80, revUnknown1000: 14993.85, revNewsletter1000: 1999.18 },
        EQUIPMENT: { revPer1000: 12752.40, revUnknown1000: 9564.30, revNewsletter1000: 1275.24 },
        VEHICLES_AND_PARTS: { revPer1000: 25592.20, revUnknown1000: 19194.15, revNewsletter1000: 2559.22 },
        HEALTH_AND_BEAUTY: { revPer1000: 6613.60, revUnknown1000: 4960.20, revNewsletter1000: 661.36 },
        ANIMALS_AND_PET_SUPPLIES: { revPer1000: 5572.00, revUnknown1000: 4179.00, revNewsletter1000: 557.20 },
        FOOD_DRINK_AND_TOBACCO: { revPer1000: 17088.00, revUnknown1000: 12816.00, revNewsletter1000: 1708.80 },
        KIDS_AND_BABIES: { revPer1000: 6675.80, revUnknown1000: 5006.85, revNewsletter1000: 667.58 },
        HOME_AND_GARDEN: { revPer1000: 11428.40, revUnknown1000: 8571.30, revNewsletter1000: 1142.84 },
        GAMES_AND_TOYS: { revPer1000: 6448.20, revUnknown1000: 4836.15, revNewsletter1000: 644.82 },
        TRAVEL_ACCESSORIES: { revPer1000: 8608.80, revUnknown1000: 6456.60, revNewsletter1000: 860.88 },
        JEWELRY: { revPer1000: 12126.80, revUnknown1000: 9095.10, revNewsletter1000: 1212.68 },
        CLOTHES_AND_ACCESSORIES: { revPer1000: 6596.60, revUnknown1000: 4947.45, revNewsletter1000: 659.66 },
        FURNITURE: { revPer1000: 9618.40, revUnknown1000: 7213.80, revNewsletter1000: 961.84 },
        HEALTH_AND_WELLNESS: { revPer1000: 6260.80, revUnknown1000: 4695.60, revNewsletter1000: 626.08 },
        OTHER: { revPer1000: 9618.40, revUnknown1000: 7213.80, revNewsletter1000: 961.84 }
      };

      const subsInput = document.getElementById('calc-subs');
      const subsRange = document.getElementById('calc-subs-range');
      const industrySelect = document.getElementById('calc-industry');
      const resultsDiv = document.getElementById('calc-results');
      let calcStarted = false;

      function fmt(n) {
        return Math.round(n).toLocaleString('pl-PL');
      }

      function calc() {
        const subs = parseInt(subsInput.value) || parseInt(subsRange.value) || 0;
        const industry = industrySelect.value;
        const data = INDUSTRY_DATA[industry] || INDUSTRY_DATA.OTHER;

        if (subs < 100) return;

        if (!calcStarted) {
          calcStarted = true;
          if (typeof gtag === 'function') {
            gtag('event', 'calculator_started', { page_variant: 'v2' });
          }
        }

        const rev1 = data.revPer1000 * (subs / 1000);
        const rev2 = rev1 + (data.revUnknown1000 * (subs * 2.5 / 1000));
        const revNL = data.revNewsletter1000 * (subs / 1000) * 2;
        const rev3 = (rev2 + revNL) * 1.15;

        animNum('calc-recover', rev3);
        document.getElementById('calc-s1').textContent = fmt(rev1) + ' z\u0142';
        document.getElementById('calc-s2').textContent = fmt(rev2 - rev1) + ' z\u0142';
        document.getElementById('calc-s3').textContent = fmt(revNL) + ' z\u0142';
        document.getElementById('calc-yearly').textContent = fmt(rev3 * 12) + ' z\u0142';

        // Update personalized CTA
        var ctaLink = document.getElementById('calc-cta-link');
        if (ctaLink && rev3 > 0) {
          ctaLink.innerHTML = 'Odzyskaj ' + fmt(rev3) + ' z\u0142/mies. <svg viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
        }

        resultsDiv.style.opacity = '1';
        resultsDiv.style.transform = 'translateY(0)';

        if (typeof gtag === 'function') {
          gtag('event', 'calculator_result', {
            calculator_type: 'revenue_recovery',
            industry: industry,
            subscribers: subs,
            monthly_recovery: Math.round(rev3),
            currency: 'PLN',
            page_variant: 'v2'
          });
        }
      }

      let af;
      function animNum(id, target) {
        var el = document.getElementById(id);
        var start = parseInt(el.textContent.replace(/[^0-9]/g, '')) || 0;
        var dur = 700;
        var t0 = performance.now();
        if (af) cancelAnimationFrame(af);
        function tick(now) {
          var p = Math.min((now - t0) / dur, 1);
          var e = 1 - Math.pow(1 - p, 3);
          el.textContent = fmt(Math.round(start + (target - start) * e));
          if (p < 1) af = requestAnimationFrame(tick);
        }
        af = requestAnimationFrame(tick);
      }

      function syncRange(input, range) {
        var v = parseInt(input.value) || 0;
        var min = parseInt(range.min);
        var max = parseInt(range.max);
        if (v >= min && v <= max) range.value = v;
      }

      subsRange.addEventListener('input', function() { subsInput.value = subsRange.value; calc(); });
      subsInput.addEventListener('input', function() { syncRange(subsInput, subsRange); calc(); });
      industrySelect.addEventListener('change', calc);

      // Preset buttons
      document.querySelectorAll('.calc-preset-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var val = parseInt(btn.getAttribute('data-val'));
          subsInput.value = val;
          syncRange(subsInput, subsRange);
          calc();
        });
      });

      // Initial calc
      subsInput.value = 5000;
      calc();
      resultsDiv.style.opacity = '1';
      resultsDiv.style.transform = 'translateY(0)';
    })();

    // ── Scroll Depth Tracking ──
    (function() {
      var tracked = {};
      var thresholds = [25, 50, 75, 100];
      window.addEventListener('scroll', function() {
        var scrollPct = Math.round((window.scrollY + window.innerHeight) / document.body.scrollHeight * 100);
        thresholds.forEach(function(t) {
          if (scrollPct >= t && !tracked[t]) {
            tracked[t] = true;
            if (typeof gtag === 'function') {
              gtag('event', 'scroll_depth', { depth: t, page_variant: 'v2' });
            }
          }
        });
      });
    })();

    // ── Bridge Viewed Tracking ──
    (function() {
      var calcSection = document.getElementById('kalkulator');
      if (calcSection && 'IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              if (typeof gtag === 'function') {
                gtag('event', 'bridge_viewed', { section: 'calculator', page_variant: 'v2' });
              }
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        obs.observe(calcSection);
      }
    })();

    // ── Marquee animation ──
    (function() {
      var style = document.createElement('style');
      style.textContent = '@keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }';
      document.head.appendChild(style);
    })();
  </script>

</LandingLayout>
