---
export const prerender = true;

import LandingLayout from '../../../layouts/LandingLayout.astro';

const steps = [
  {
    phase: 1,
    num: 1,
    title: 'Ative sua conta Freemium gratuita',
    time: '5 min',
    summary: 'Cadastre-se no edrone sem cartão de crédito e sem compromisso. O Freemium libera todas as funcionalidades principais para você ganhar confiança antes de pagar.',
    details: [
      'Acesse control.edrone.me/register',
      'Informe a URL da sua loja e dados de contato',
      'Confirme seu e-mail',
      'Pronto — seu painel edrone está esperando por você'
    ],
    cta: { label: 'Criar conta', href: 'https://control.edrone.me/register' },
    help: { label: 'O que é a conta Freemium?', href: 'https://help.edrone.me/pt/articles/11197093' }
  },
  {
    phase: 1,
    num: 2,
    title: 'Conheça o Painel de Atividades',
    time: '10 min',
    summary: 'Seu centro de comando. Um só lugar para ver todas as automações, campanhas e resultados — sem ter que navegar por menus.',
    details: [
      'Faça login no painel edrone',
      'Abra a aba Painel de Atividades',
      'Veja seus cenários ativos e campanhas recentes',
      'Confira métricas-chave: aberturas, cliques, receita'
    ],
    cta: { label: 'Abrir painel', href: 'https://control.edrone.me/login' },
    help: { label: 'O que encontro no Painel de Atividades?', href: 'https://help.edrone.me/pt/articles/11197133' }
  },
  {
    phase: 1,
    num: 3,
    title: 'Assista aos treinamentos de onboarding',
    time: '30 min',
    summary: 'Vídeos curtos e objetivos que te guiam pela configuração e primeiras campanhas. Poupam horas de tentativa e erro.',
    details: [
      'Newsletter Quick Start — 20 minutos até sua primeira campanha pronta',
      'Fundamentos de cenários de automação',
      'Configuração de pop-ups e formulários de cadastro',
      'Como ler suas métricas sem ser especialista'
    ],
    cta: { label: 'Ver treinamentos', href: 'https://help.edrone.me/pt/articles/8333358' },
    help: { label: 'Newsletter Quick Start (vídeo)', href: 'https://help.edrone.me/pt/articles/8721433' }
  },
  {
    phase: 2,
    num: 4,
    title: 'Integre sua loja ao edrone',
    time: '20 min',
    summary: 'Conecte VTEX, Shopify, WooCommerce, Nuvemshop, Tray, Loja Integrada ou Magento. A integração ativa o rastreamento de comportamento e a sincronização de produtos.',
    details: [
      'No painel edrone, vá em Integrações → escolha sua plataforma',
      'Instale o plugin ou cole o script de tracking',
      'Verifique se o tracker está enviando dados (Painel de Atividades)',
      'Confirme que clientes e pedidos sincronizam corretamente'
    ],
    cta: { label: 'Ir para Integrações', href: 'https://control.edrone.me/login' },
    help: { label: 'Como integrar minha loja?', href: 'https://help.edrone.me/pt/articles/8333407' }
  },
  {
    phase: 2,
    num: 5,
    title: 'Envie seu feed de produtos',
    time: '15 min',
    summary: 'O feed de produtos alimenta cenários de carrinho abandonado, recomendações e conteúdo dinâmico nos e-mails. Sem ele, as automações não sabem o que você vende.',
    details: [
      'Pegue a URL do seu feed XML (a maioria das plataformas gera automaticamente)',
      'No painel edrone: Produtos → Adicionar feed',
      'Cole a URL e escolha a frequência de atualização',
      'Confirme que os produtos importaram com preços e imagens'
    ],
    cta: { label: 'Adicionar feed', href: 'https://control.edrone.me/login' },
    help: { label: 'Como enviar um feed de produtos?', href: 'https://help.edrone.me/pt/articles/8333380' }
  },
  {
    phase: 2,
    num: 6,
    title: 'Comece a construir sua base de assinantes',
    time: 'contínuo',
    summary: 'Sem lista, não há marketing automation. Colete os primeiros assinantes antes de lançar sua primeira campanha — é o que faz todo o resto funcionar.',
    details: [
      'Lance um pop-up de boas-vindas com desconto pelo cadastro',
      'Adicione checkbox de consentimento no checkout',
      'Coloque um formulário de cadastro no rodapé da loja',
      'Colete opt-ins offline também (loja física, eventos)'
    ],
    cta: { label: 'Ver boas práticas', href: 'https://help.edrone.me/pt/articles/8297150' },
    help: { label: 'Como construir uma base de assinantes?', href: 'https://help.edrone.me/pt/articles/8297150' }
  },
  {
    phase: 3,
    num: 7,
    title: 'Envie sua primeira newsletter',
    time: '20 min',
    summary: 'O Quick Start é o caminho mais rápido até uma campanha no ar. Em 20 minutos sua primeira newsletter pode estar na caixa de entrada dos seus clientes.',
    details: [
      'Escolha um template da biblioteca do edrone',
      'Edite texto, imagens e CTA',
      'Defina seu segmento de público',
      'Envie teste para você → aprove → envie para a base'
    ],
    cta: { label: 'Criar newsletter', href: 'https://control.edrone.me/login' },
    help: { label: 'Como enviar minha primeira newsletter?', href: 'https://help.edrone.me/pt/articles/8300487' }
  },
  {
    phase: 3,
    num: 8,
    title: 'Ative sua primeira automação',
    time: '15 min',
    summary: 'Carrinho abandonado é o cenário que retorna mais rápido. Taxa de abertura média de 51% e as primeiras vendas recuperadas em 48 horas.',
    details: [
      'Painel → Automações → Carrinho abandonado',
      'Use o template pronto do edrone',
      'Configure o delay (ex: 1h após o abandono)',
      'Ative — o cenário roda sozinho a partir daqui'
    ],
    cta: { label: 'Ativar automação', href: 'https://control.edrone.me/login' },
    help: { label: 'Qual cenário ativar primeiro?', href: 'https://help.edrone.me/pt/articles/8300376' }
  },
  {
    phase: 3,
    num: 9,
    title: 'E agora? — Explore funcionalidades avançadas',
    time: 'próximo',
    summary: 'Você já tem o básico. Agora vem a personalização, segmentação avançada, pop-ups onsite e cross-channel — é aí que mora o 7× ROI.',
    details: [
      'Adicione cenários de win-back e cross-sell',
      'Configure pop-ups com triggers inteligentes',
      'Conecte SMS e Web Push',
      'Monte relatórios e confira seu ROI em 30 dias'
    ],
    cta: { label: 'Ver roadmap', href: 'https://help.edrone.me/pt/articles/8320343' },
    help: { label: 'Já integrei — e agora?', href: 'https://help.edrone.me/pt/articles/8320343' }
  }
];

const phases = [
  { num: 1, name: 'Comece', color: 'var(--yellow)', desc: 'Conheça o sistema e crie sua conta' },
  { num: 2, name: 'Conecte', color: 'var(--turquoise)', desc: 'Integre sua loja e seus dados' },
  { num: 3, name: 'Lance', color: 'var(--pink)', desc: 'Ative campanhas e comece a faturar' }
];
---

<LandingLayout
  title="Primeiros passos com edrone — guia interativo de onboarding"
  description="9 passos práticos que te levam do cadastro até sua primeira receita com marketing automation. Acompanhe seu progresso, marque a checklist, aprenda edrone no seu ritmo."
  lang="pt-BR"
  ogTitle="Primeiros passos com edrone — ative marketing automation em 30 dias"
  ogDescription="Guia interativo: 9 passos, 3 fases, onboarding completo. Marque o que fez e veja seu progresso crescer."
  ogUrl="https://roi.edrone.me/br/primeiros-passos/"
  googleFont="Roboto:ital,wght@0,400;0,500;0,700;0,900"
>

<style>
  :root { --ink: #2E2E29; --ink-soft: #5A5A52; --line: rgba(46,46,41,0.10); --done-bg: #EDF9EF; --done-stroke: #54B767; }
  body { background: #FAFAF7; }
  .header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--line); }
  .header-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .logo svg { display: block; height: 22px; }
  .hdr-actions { display: flex; gap: 12px; align-items: center; }
  .btn-login { font-size: 14px; font-weight: 500; color: var(--ink); text-decoration: none; padding: 8px 14px; border-radius: 100px; transition: background 0.2s; }
  .btn-login:hover { background: rgba(0,0,0,0.05); }
  .btn-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--yellow); color: var(--ink); font-weight: 700; font-size: 14px; padding: 10px 22px; border-radius: 100px; text-decoration: none; transition: transform 0.15s, box-shadow 0.2s; }
  .btn-cta:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(255,255,140,0.5); }
  .hero { padding: 80px 24px 48px; background: radial-gradient(ellipse at top, rgba(255,255,140,0.4) 0%, transparent 60%), #FAFAF7; text-align: center; }
  .hero-inner { max-width: 780px; margin: 0 auto; }
  .eyebrow { display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,140,0.5); color: var(--ink); padding: 8px 16px; font-size: 13px; font-weight: 700; letter-spacing: 0.02em; text-transform: uppercase; border-radius: 100px; margin-bottom: 24px; }
  .eyebrow-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--done-stroke); }
  h1.hero-title { font-family: 'Sans Pro', 'Roboto', sans-serif; font-weight: 700; font-size: clamp(38px, 6vw, 64px); line-height: 1.05; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 20px; }
  h1.hero-title .accent { background: var(--yellow); padding: 0 10px; border-radius: 8px; display: inline-block; }
  .hero-sub { font-size: 19px; line-height: 1.55; color: var(--ink-soft); max-width: 620px; margin: 0 auto 32px; }
  .hero-stats { display: flex; justify-content: center; gap: 40px; flex-wrap: wrap; margin-top: 8px; }
  .hero-stat strong { display: block; font-family: 'Sans Pro', sans-serif; font-size: 32px; font-weight: 700; color: var(--ink); line-height: 1; }
  .hero-stat span { display: block; margin-top: 4px; font-size: 13px; color: var(--ink-soft); }
  .progress-wrap { position: sticky; top: 64px; z-index: 50; background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); padding: 14px 24px; }
  .progress-inner { max-width: 1000px; margin: 0 auto; display: flex; align-items: center; gap: 20px; }
  .progress-label { font-size: 13px; font-weight: 500; color: var(--ink-soft); white-space: nowrap; }
  .progress-label strong { color: var(--ink); font-weight: 700; }
  .progress-bar { flex: 1; height: 10px; background: var(--line); border-radius: 100px; overflow: hidden; position: relative; }
  .progress-fill { height: 100%; background: linear-gradient(90deg, var(--yellow) 0%, var(--turquoise) 50%, var(--pink) 100%); width: 0%; transition: width 0.6s cubic-bezier(0.2, 0.9, 0.3, 1); border-radius: 100px; }
  .progress-phases { display: flex; gap: 8px; }
  .phase-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--line); transition: all 0.3s; }
  .phase-dot.partial { background: var(--yellow); box-shadow: 0 0 0 3px rgba(255,255,140,0.3); }
  .phase-dot.done { background: var(--done-stroke); box-shadow: 0 0 0 3px rgba(84,183,103,0.25); }
  .reset-btn { background: none; border: 1px solid var(--line); color: var(--ink-soft); padding: 6px 14px; font-size: 12px; font-weight: 500; border-radius: 100px; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .reset-btn:hover { background: var(--line); color: var(--ink); }
  .usp { padding: 64px 24px 24px; }
  .usp-inner { max-width: 1000px; margin: 0 auto; }
  .usp-eyebrow { display: inline-block; background: var(--ink); color: #fff; padding: 6px 14px; font-size: 12px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; border-radius: 100px; margin-bottom: 16px; }
  .usp h2 { font-family: 'Sans Pro', sans-serif; font-size: clamp(26px, 3.2vw, 36px); font-weight: 700; line-height: 1.15; color: var(--ink); margin-bottom: 12px; max-width: 720px; }
  .usp-intro { font-size: 17px; color: var(--ink-soft); max-width: 640px; line-height: 1.55; margin-bottom: 36px; }
  .usp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .usp-card { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 28px 24px; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
  .usp-card:hover { transform: translateY(-3px); border-color: rgba(46,46,41,0.2); box-shadow: 0 12px 28px rgba(0,0,0,0.06); }
  .usp-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; font-size: 22px; }
  .usp-icon.yellow { background: var(--yellow); }
  .usp-icon.turquoise { background: var(--turquoise); }
  .usp-icon.pink { background: var(--pink); }
  .usp-card h3 { font-family: 'Sans Pro', sans-serif; font-size: 18px; font-weight: 700; line-height: 1.25; color: var(--ink); margin-bottom: 8px; }
  .usp-card p { font-size: 14.5px; line-height: 1.55; color: var(--ink-soft); }
  .phase { padding: 72px 24px 40px; }
  .phase-inner { max-width: 860px; margin: 0 auto; }
  .phase-header { display: flex; align-items: center; gap: 16px; margin-bottom: 40px; }
  .phase-badge { width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-family: 'Sans Pro', sans-serif; font-size: 24px; font-weight: 700; color: var(--ink); flex-shrink: 0; }
  .phase h2 { font-family: 'Sans Pro', sans-serif; font-size: 32px; font-weight: 700; line-height: 1.15; color: var(--ink); }
  .phase-desc { font-size: 15px; color: var(--ink-soft); margin-top: 2px; }
  .steps { display: flex; flex-direction: column; gap: 16px; }
  .step { background: #fff; border: 1px solid var(--line); border-radius: 20px; padding: 0; transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s; overflow: hidden; }
  .step:hover { border-color: rgba(46,46,41,0.2); box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
  .step.done { background: var(--done-bg); border-color: rgba(84,183,103,0.3); }
  .step-header { display: flex; align-items: center; gap: 20px; padding: 24px 28px; cursor: pointer; user-select: none; }
  .step-check { width: 32px; height: 32px; border: 2px solid var(--line); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.2s; background: #fff; cursor: pointer; }
  .step-check:hover { border-color: var(--ink); }
  .step.done .step-check { background: var(--done-stroke); border-color: var(--done-stroke); }
  .step-check svg { width: 16px; height: 16px; stroke: #fff; opacity: 0; transition: opacity 0.2s; }
  .step.done .step-check svg { opacity: 1; }
  .step-num { font-family: 'Sans Pro', sans-serif; font-size: 14px; font-weight: 700; color: var(--ink-soft); letter-spacing: 0.05em; flex-shrink: 0; }
  .step-title-wrap { flex: 1; min-width: 0; }
  .step-title { font-family: 'Sans Pro', sans-serif; font-size: 19px; font-weight: 700; line-height: 1.3; color: var(--ink); }
  .step.done .step-title { text-decoration: line-through; text-decoration-thickness: 2px; text-decoration-color: rgba(84,183,103,0.4); color: var(--ink-soft); }
  .step-time { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 500; color: var(--ink-soft); background: var(--line); padding: 4px 10px; border-radius: 100px; flex-shrink: 0; }
  .step.done .step-time { background: rgba(84,183,103,0.15); color: var(--done-stroke); }
  .step-toggle { width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; transition: transform 0.3s; color: var(--ink-soft); }
  .step.open .step-toggle { transform: rotate(180deg); }
  .step-body { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.35s cubic-bezier(0.2, 0.9, 0.3, 1); }
  .step.open .step-body { grid-template-rows: 1fr; }
  .step-body-inner { overflow: hidden; min-height: 0; }
  .step-content { padding: 0 28px 28px 84px; border-top: 1px solid var(--line); padding-top: 20px; }
  .step.done .step-content { border-top-color: rgba(84,183,103,0.2); }
  .step-summary { font-size: 15px; line-height: 1.6; color: var(--ink-soft); margin-bottom: 16px; }
  .step-checklist { list-style: none; padding: 0; margin: 0 0 20px; }
  .step-checklist li { display: flex; gap: 12px; padding: 8px 0; font-size: 14.5px; line-height: 1.55; color: var(--ink); }
  .step-checklist li::before { content: ''; width: 6px; height: 6px; background: var(--ink); border-radius: 50%; flex-shrink: 0; margin-top: 9px; }
  .step-actions { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .step-action { display: inline-flex; align-items: center; gap: 6px; font-size: 14px; font-weight: 600; padding: 10px 18px; border-radius: 100px; text-decoration: none; transition: all 0.2s; }
  .action-primary { background: var(--ink); color: #fff; }
  .action-primary:hover { background: #000; transform: translateY(-1px); }
  .action-secondary { background: transparent; color: var(--ink); border: 1px solid var(--line); }
  .action-secondary:hover { border-color: var(--ink); }
  .action-done { background: var(--yellow); color: var(--ink); font-family: inherit; border: none; cursor: pointer; }
  .action-done:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(255,255,140,0.5); }
  .action-done.checked { background: var(--done-stroke); color: #fff; }
  .step-action svg { width: 14px; height: 14px; }
  .celebration { position: fixed; inset: 0; z-index: 1000; display: none; align-items: center; justify-content: center; background: rgba(46,46,41,0.65); backdrop-filter: blur(8px); padding: 24px; }
  .celebration.show { display: flex; animation: fadeIn 0.4s ease; }
  .celebration-card { background: #fff; border-radius: 24px; padding: 48px 40px; max-width: 460px; text-align: center; box-shadow: 0 20px 80px rgba(0,0,0,0.25); position: relative; animation: popIn 0.5s cubic-bezier(0.2, 0.9, 0.3, 1.15); }
  .celebration-emoji { font-size: 64px; line-height: 1; margin-bottom: 16px; }
  .celebration h3 { font-family: 'Sans Pro', sans-serif; font-size: 28px; font-weight: 700; color: var(--ink); margin-bottom: 12px; }
  .celebration p { color: var(--ink-soft); font-size: 16px; margin-bottom: 24px; line-height: 1.5; }
  .celebration-close { position: absolute; top: 16px; right: 16px; background: none; border: none; width: 32px; height: 32px; cursor: pointer; color: var(--ink-soft); font-size: 20px; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes popIn { from { opacity: 0; transform: scale(0.85) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
  .footer-cta { padding: 80px 24px 100px; text-align: center; background: var(--ink); color: #fff; }
  .footer-cta h2 { font-family: 'Sans Pro', sans-serif; font-size: clamp(28px, 4vw, 44px); font-weight: 700; line-height: 1.1; margin-bottom: 16px; }
  .footer-cta h2 .accent { background: var(--yellow); color: var(--ink); padding: 0 10px; border-radius: 6px; }
  .footer-cta p { font-size: 17px; color: rgba(255,255,255,0.7); margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
  .footer-cta .btn-cta { font-size: 16px; padding: 16px 32px; }
  .footer-note { margin-top: 24px; font-size: 13px; color: rgba(255,255,255,0.5); }
  .footer-note a { color: var(--yellow); text-decoration: none; }
  @media (max-width: 720px) { .usp { padding: 40px 20px 16px; } .usp-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) {
    .hero { padding: 56px 20px 36px; }
    .hero-stats { gap: 24px; }
    .progress-phases { display: none; }
    .phase { padding: 48px 20px 28px; }
    .step-header { padding: 18px 20px; gap: 14px; }
    .step-content { padding: 16px 20px 24px; }
    .step-num { display: none; }
    .step-title { font-size: 16.5px; }
    .step-time { display: none; }
    .footer-cta { padding: 60px 20px 80px; }
  }
</style>

<header class="header">
  <div class="header-inner">
    <a href="https://edrone.me" class="logo" aria-label="edrone">
      <svg viewBox="0 0 120 32"><text x="0" y="24" font-family="Sans Pro, Roboto, sans-serif" font-size="22" font-weight="700" fill="#2E2E29">edrone</text></svg>
    </a>
    <div class="hdr-actions">
      <a href="https://control.edrone.me/login" class="btn-login">Entrar</a>
      <a href="https://control.edrone.me/register" class="btn-cta">
        Criar conta grátis
        <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</header>

<section class="hero">
  <div class="hero-inner">
    <span class="eyebrow"><span class="eyebrow-dot"></span>Guia interativo de onboarding</span>
    <h1 class="hero-title">Primeiros passos <br>com <span class="accent">edrone</span>.</h1>
    <p class="hero-sub"><strong>A potência de um CRM enterprise. A simplicidade de uma ferramenta que você não precisa aprender.</strong><br>9 tarefas concretas em 3 fases — do cadastro à sua primeira receita com marketing automation. Marque o que já fez, seu progresso é salvo automaticamente.</p>
    <div class="hero-stats">
      <div class="hero-stat"><strong>~2h</strong><span>setup completo</span></div>
      <div class="hero-stat"><strong>9</strong><span>passos</span></div>
      <div class="hero-stat"><strong>7×</strong><span>ROI em 3 meses</span></div>
    </div>
  </div>
</section>

<div class="progress-wrap">
  <div class="progress-inner">
    <span class="progress-label"><strong id="progress-count">0</strong> de 9 concluídos</span>
    <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
    <div class="progress-phases">
      <span class="phase-dot" id="phase-dot-1" title="Comece"></span>
      <span class="phase-dot" id="phase-dot-2" title="Conecte"></span>
      <span class="phase-dot" id="phase-dot-3" title="Lance"></span>
    </div>
